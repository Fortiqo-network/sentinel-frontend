# ──────────────────────────────────────────────────────────────────────────────
# sentinel-frontend — environment variables
# Copy this file to .env.local and fill in the values. Never commit .env.local.
# NEXT_PUBLIC_* values are baked into the client bundle at build time.
# All other values are server-only (never exposed to the browser).
# ──────────────────────────────────────────────────────────────────────────────

# ── Public (baked at build time) ─────────────────────────────────────────────

# Base URL of the API gateway (no trailing slash).
# Used by BOTH the server-side BFF (/api/* route handlers forward here) and by
# server-side rendering of public reads (marketplace listings, agent detail).
# The browser itself never calls the gateway directly — it calls the same-origin
# BFF under /api. NEXT_PUBLIC_* values are readable on the server too, so this
# one variable is all the BFF needs.
# Production: https://sentinel-api.fortiqo.xyz
NEXT_PUBLIC_GATEWAY_URL=https://sentinel-api.fortiqo.xyz

# Public URL of this application (used for OIDC redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OIDC public client ID (PKCE flow — safe to expose)
NEXT_PUBLIC_OIDC_CLIENT_ID=sentinel-web

# Stripe publishable key (safe to expose; card data goes to Stripe, not us)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Google OAuth 2.0 Client ID (public — safe to expose). Enables "Sign in with
# Google" on the auth screens. Create at Google Cloud Console → APIs & Services
# → Credentials → OAuth client ID (Web application). Add each app origin to
# "Authorized JavaScript origins" (e.g. http://localhost:3000 and your prod
# origin). The GSI button flow uses NO redirect URI, so "Authorized redirect
# URIs" can be left empty. Must equal core-api's GOOGLE_OAUTH_CLIENT_ID. Leave
# empty to hide the Google button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# X (Twitter) OAuth 2.0 — server-only (the BFF at /api/v1/auth/x/* builds the
# authorize URL and handles the callback). NOT NEXT_PUBLIC — the browser never
# needs it and the client secret lives only in core-api. TWITTER_REDIRECT_URI
# must match the Callback URI registered on the X app exactly (e.g.
# http://127.0.0.1:3000/api/v1/auth/x/callback in dev). Leave TWITTER_CLIENT_ID
# empty to hide the X button.
TWITTER_CLIENT_ID=
TWITTER_REDIRECT_URI=http://127.0.0.1:3000/api/v1/auth/x/callback

# Error monitoring (Sentry) — optional in dev
NEXT_PUBLIC_SENTRY_DSN=

# Product analytics (PostHog) — optional in dev
NEXT_PUBLIC_POSTHOG_KEY=

# Feature flags endpoint — optional
NEXT_PUBLIC_FEATURE_FLAGS_URL=

# MCP base URL shown in the connect panel
NEXT_PUBLIC_MCP_BASE=https://mcp.sentinel.xyz

# Show the "Test payment (mock)" option on the billing page — a pre-launch
# simulator (must also have MOCK_PAYMENTS_ENABLED=true in sentinel-billing).
# Leave unset/false in real production; set "true" to demo the money flow
# without a real gateway. Baked at build time.
NEXT_PUBLIC_MOCK_PAYMENTS=false

# ── Server-only (never exposed to browser) ───────────────────────────────────

# OIDC issuer URL (used by the BFF for token exchange)
OIDC_ISSUER=https://auth.sentinel.xyz

# Confidential client secret for BFF token exchange
OIDC_CLIENT_SECRET=

# Secret used to sign session cookies (at least 32 random bytes, hex or base64)
SESSION_SECRET=

# ── CSRF (double-submit token) ────────────────────────────────────────────────
# The BFF always issues a readable `sentinel_csrf` cookie alongside the session
# and the client always echoes it in the `X-CSRF-Token` header on unsafe
# requests. This flag only controls ENFORCEMENT:
#   unset / "false" (default) → dark mode: mismatches are recorded (response
#     header `x-csrf-dark`) but allowed. Ship here first.
#   "true" → the edge middleware rejects unsafe `/api/*` requests whose header
#     does not match the cookie with 403.
# Rollout: deploy dark, confirm a live logged-in session sends the header, THEN
# set this to "true" and redeploy — already-loaded clients are already compliant,
# so there is no lockout. Session-establishing auth routes are always exempt.
CSRF_ENFORCED=false
